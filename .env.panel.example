# ─── Senitnal Panel — Environment Variables ───────────────────────────────────
# Copy to .env.panel and fill in values. Never commit .env.panel to git.

# ─── API Config ───────────────────────────────────────────────────────────────
PANEL_API_PORT=3787
PANEL_API_HOST=0.0.0.0

# JWT signing secret — MUST be changed in production (min 32 chars)
PANEL_JWT_SECRET=change-me-in-production-must-be-at-least-32-chars

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Local dev credentials (ignored in production — Cloudflare Access used instead)
PANEL_AUTH_EMAIL=panel@senitnal.local
# If not set, a random password is auto-generated and printed on startup
PANEL_AUTH_PASSWORD=

# ─── Environment ──────────────────────────────────────────────────────────────
# production = Cloudflare Access auth required, local login disabled
# development = local email/password auth enabled
NODE_ENV=development

# ─── Cloudflare Access (production only) ─────────────────────────────────────
# CF_ACCESS_TEAM_DOMAIN=your-team.cloudflareaccess.com
# CF_ACCESS_AUD=your-application-audience-tag

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://sentinel-panel-redis:6379
